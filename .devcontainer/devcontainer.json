{
  "name": "ROS2 Jazzy Dev",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "ros2_jazzy_dev",
  "workspaceFolder": "/ros2_ws",
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteUser": "root",
  "postCreateCommand": "rosdep update || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-ros-dev.ros",
        "ms-python.python"
      ]
    }
  }
}
